# ── Root .gitignore ──

# Environment files (contain secrets)
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
*.pyo

# Logs
*.log

#Data
data

# Docker Compose override (local/server-specific config)
docker-compose.override.yml
